{
  "book_id": "2",
  "title": "دیوان حافظ",
  "chapters": [
    {
      "id": "2_ch1",
      "title": "غزلیات",
      "subtitle": "گزیده غزل‌های حافظ",
      "items": [
        {
          "id": "2_p1",
          "title": "الا یا أیها الساقی",
          "type": "poem",
          "audio_url": "https://cdn.shopify.com/s/files/1/0943/1446/3572/files/5d70fa710778acc4c0dbe5277fc0edf0.mp3",
          "content": [
            "الا یا أیها الساقی أَدِر کأساً وناوِلها",
            "که عشق آسان نمود اول ولی افتاد مشکل‌ها",
            "",
            "به بوی نافه‌ای کاخر صبا زان طره بگشاید",
            "ز تاب جعد مشکینش چه خون افتاد در دل‌ها"
          ]
        },
        {
          "id": "2_p2",
          "title": "صبا به لطف بگو",
          "type": "poem",
          "audio_url": "https://cdn.shopify.com/s/files/1/0943/1446/3572/files/5d70fa710778acc4c0dbe5277fc0edf0.mp3",
          "content": [
            "صبا به لطف بگو آن غزال رعنا را",
            "که سر به کوه و بیابان تو داده‌ای ما را",
            "",
            "شکرفروش که عمرش دراز باد چرا",
            "تفقدی نکند طوطی شکرخا را"
          ]
        }
      ]
    },
    {
      "id": "2_ch2",
      "title": "رباعیات",
      "subtitle": "رباعیات حافظ",
      "items": [
        {
          "id": "2_p3",
          "title": "رباعی اول",
          "type": "poem",
          "audio_url": "https://cdn.shopify.com/s/files/1/0943/1446/3572/files/5d70fa710778acc4c0dbe5277fc0edf0.mp3",
          "content": [
            "ای دل به کوی عشق گذاری نمی‌کنی",
            "اسباب جمع داری و کاری نمی‌کنی",
            "عمری بر آب و آتش و خاک و هوا گذشت",
            "یک لحظه فکر آب و هوایی نمی‌کنی"
          ]
        }
      ]
    },
    {
      "id": "2_ch3",
      "title": "قصاید",
      "subtitle": "قصاید حافظ",
      "items": [
        {
          "id": "2_p4",
          "title": "قصیده اول",
          "type": "poem",
          "audio_url": "https://cdn.shopify.com/s/files/1/0943/1446/3572/files/5d70fa710778acc4c0dbe5277fc0edf0.mp3",
          "content": [
            "بیا که قصر امل سخت سست بنیاد است",
            "بیار باده که بنیاد عمر بر باد است"
          ]
        }
      ]
    }
  ]
}