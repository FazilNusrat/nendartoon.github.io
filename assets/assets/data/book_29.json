  "title": "کتاب امتحانی",
  "chapters": [
    {
      "id": "29_ch1",
      "title": "باب اول: در عدل و تدبیر",
      "subtitle": "حکایت‌هایی درباره عدالت",
      "items": [
        {
          "id": "29_p1",
          "title": "حکایت اول",
          "type": "poem",
          "audio_url": "https://cdn.shopify.com/s/files/1/0943/1446/3572/files/5d70fa710778acc4c0dbe5277fc0edf0.mp3",
          "content": [
            "بنی‌آدم اعضای یک پیکرند",
            "که در آفرینش ز یک گوهرند",
            "",
            "چو عضوی به درد آورد روزگار",
            "دگر عضوها را نماند قرار"
          ]
        },
        {
          "id": "29_p2",
          "title": "حکایت دوم",
          "type": "poem",
          "audio_url": "https://cdn.shopify.com/s/files/1/0943/1446/3572/files/5d70fa710778acc4c0dbe5277fc0edf0.mp3",
          "content": [
            "توانا بود هر که دانا بود",
            "ز دانش دل پیر برنا بود",
            "",
            "چو دانش نباشد سر و دستگاه",
            "نه دیهیم شاهی نه تخت و کلاه"
          ]
        }
      ]
    },
    {
      "id": "29_ch2",
      "title": "باب دوم: در احسان",
      "subtitle": "حکایت‌هایی درباره نیکوکاری",
      "items": [
        {
          "id": "29_p3",
          "title": "در باب نیکوکاری",
          "type": "poem",
          "audio_url": "https://cdn.shopify.com/s/files/1/0943/1446/3572/files/5d70fa710778acc4c0dbe5277fc0edf0.mp3",
          "content": [
            "کریمان جان‌فشانان را دعا گوی",
            "که پیش دوستان کشته شوی کوی",
            "",
            "نه هر کس را که خواهی دوست داری",
            "کسی را دوست دار اهل وفاداری"
          ]
        }
      ]
    }
  ]
}